[global]
follow = mouse
origin = bottom-right
offset = (16, 16)
height = (64, 512)
width = (256, 512)
sort = update
notification_limit = 8
show_age_threshold = 30
stack_duplicates = false
indicate_hidden = true
show_indicators = true
gap_size = 8
background = "#181818E8"
frame_width = 0
corner_radius = 12
min_icon_size = 48
max_icon_size = 48
padding = 12
horizontal_padding = 12
text_icon_padding = 4
highlight = "#81C995"
progress_bar = true
progress_bar_height = 12
progress_bar_min_width = 128
progress_bar_max_width = 512
progress_bar_frame_width = 0
progress_bar_corner_radius = 6
icon_path = "/usr/share/icons/Tela-circle-dark/24/panel/:/usr/share/icons/Tela-circle-dark/scalable/devices/:/usr/share/icons/Tela-circle-dark/scalable/apps/:/usr/share/icons/Tela-circle-dark/scalable/mimetypes/"
font = "system-ui 12"
format = "<big><b>%s</b></big>\n%b"
script = "~/.config/dunst/dunst.sh"
dmenu = "~/.config/wofi/dunst.sh"
mouse_left_click = close_current
mouse_right_click = context
mouse_middle_click = none

[experimental]
pause_on_mouse_over = true

[urgency_low]
foreground = "#B0B0B0"
default_icon = "state-information"

[urgency_normal]
foreground = "#FFFFFF"
default_icon = "notification-symbolic"

[urgency_critical]
foreground = "#B02020"
default_icon = "state-warning"
